---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="Professional Experience">
  <h2 style="color: #003366; text-align: center; margin-bottom: 40px;">Professional Journey</h2>

  <div style="position: relative; padding-left: 30px; border-left: 2px solid #a2c2e1; margin-bottom: 40px;">
    <div style="position: absolute; left: -11px; top: 0; width: 20px; height: 20px; background: #0056b3; border-radius: 50%;"></div>
    <span style="color: #0056b3; font-weight: bold;">Nov 2025 - Current</span>
    <h3 style="margin: 5px 0;">Optical Consultant — ***** Eye Care</h3>
    <ul style="margin-top: 10px; color: #444;">
      <li>Mastered skills in fixing luxury eyewear.</li>
      <li>Consistently exceed sales quotas through personalized service.</li>
      <li>Expertly assess and fulfill patient eye care needs.</li>
    </ul>
  </div>

  <div style="position: relative; padding-left: 30px; border-left: 2px solid #a2c2e1; margin-bottom: 40px;">
    <div style="position: absolute; left: -11px; top: 0; width: 20px; height: 20px; background: #a2c2e1; border-radius: 50%;"></div>
    <span style="color: #0056b3; font-weight: bold;">Jan 2024 – Sep 2025</span>
    <h3 style="margin: 5px 0;">Optometric Technician — National Vision/America’s Best</h3>
    <ul style="margin-top: 10px; color: #444;">
      <li>Assisted Optometrists via high-tech remote digital systems.</li>
      <li>Proficiency in tonometer, autorefractor, and retinal imaging.</li>
      <li>Trained new contact lens wearers with patience and care.</li>
    </ul>
  </div>

  <div style="position: relative; padding-left: 30px; border-left: 2px solid #a2c2e1; margin-bottom: 40px;">
    <div style="position: absolute; left: -11px; top: 0; width: 20px; height: 20px; background: #a2c2e1; border-radius: 50%;"></div>
    <span style="color: #0056b3; font-weight: bold;">Feb 2022 – Dec 2023</span>
    <h3 style="margin: 5px 0;">Retail Banker — Woodforest Bank</h3>
    <p><em>Empowering customers through financial literacy and proactive branch management.</em></p>
  </div>

  <div style="position: relative; padding-left: 30px; border-left: 2px solid #a2c2e1;">
    <div style="position: absolute; left: -11px; top: 0; width: 20px; height: 20px; background: #a2c2e1; border-radius: 50%;"></div>
    <span style="color: #0056b3; font-weight: bold;">2011 – 2013</span>
    <h3 style="margin: 5px 0;">Multi-Store Manager — Salvation Army</h3>
    <p>Simultaneously managed performance and employee development across 3 locations.</p>
  </div>
</MainLayout>
