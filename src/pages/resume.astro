---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="Resume | Karen Arze">
    <div class="page-header">
        <h1 style="font-size: 3.5rem;">Curriculum Vitae</h1>
        <p style="letter-spacing: 2px;">A legacy of excellence in eye care and finance.</p>
    </div>

    <section style="max-width: 800px; margin: 0 auto;">
        <div style="margin-bottom: 60px; position: relative; padding-left: 40px; border-left: 1px solid var(--gold);">
            <div style="position: absolute; left: -5px; top: 0; width: 10px; height: 10px; background: var(--navy); border-radius: 50%;"></div>
            <h3 style="margin: 0; font-size: 1.8rem;">Optical Consultant</h3>
            <p style="color: var(--gold); font-weight: 600;">Beach Eye Care | Nov 2025 – Present</p>
            <ul style="line-height: 1.8; color: #555;">
                <li>Specialized skills in the precision repair and adjustment of luxury eyewear.</li>
                <li>Consistently meeting and exceeding quarterly sales quotas.</li>
                <li>Expertly identifying and resolving complex patient eye care needs.</li>
            </ul>
        </div>

        <div style="margin-bottom: 60px; position: relative; padding-left: 40px; border-left: 1px solid var(--gold);">
            <h3 style="margin: 0; font-size: 1.8rem;">Optometric Technician & Sales</h3>
            <p style="color: var(--gold); font-weight: 600;">National Vision/America’s Best | Jan 2024 – Sep 2025</p>
            <ul style="line-height: 1.8; color: #555;">
                <li>Orchestrated remote optometrist systems to provide comprehensive digital eye testing.</li>
                <li>Proficient in Tonometer, Autorefractor, Retinal Imaging, and Visual Field testing.</li>
                <li>Determined insurance eligibility and managed high-volume scheduling.</li>
                <li>Certified trainer for new contact lens wearers.</li>
            </ul>
        </div>

        <div style="margin-bottom: 60px; position: relative; padding-left: 40px; border-left: 1px solid var(--gold);">
            <h3 style="margin: 0; font-size: 1.8rem;">Retail Banker</h3>
            <p style="color: var(--gold); font-weight: 600;">Woodforest Bank | Feb 2022 – Dec 2023</p>
            <ul style="line-height: 1.8; color: #555;">
                <li>Provided financial literacy to address customer concerns.</li>
                <li>Processed high-stakes transactions.</li>
                <li>Managed vault/ATM balancing.</li>
                <li>Maintained Microsoft Office proficiency.</li>
            </ul>
        </div>

        <div style="margin-bottom: 60px; position: relative; padding-left: 40px; border-left: 1px solid var(--gold);">
            <h3 style="margin: 0; font-size: 1.8rem;">Multi-Store Manager</h3>
            <p style="color: var(--gold); font-weight: 600;">Salvation Army | 2011 – 2013</p>
            <ul style="line-height: 1.8; color: #555;">
                <li>Managed employee performance and store layouts for three separate locations simultaneously.</li>
                <li>Utilizing product research for expert pricing.</li>
                <li>Organized the intake of product as well as the layout of multiple stores within the organization.</li>
            </ul>
        </div>
    </section>
</MainLayout>
