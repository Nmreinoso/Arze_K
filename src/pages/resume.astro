---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="Career Journey">
  <div class="glass-card">
    <h2 style="font-size: 2.5rem; text-align: center; margin-bottom: 4rem;">The Career Journey</h2>

    <div style="display: flex; gap: 2rem; margin-bottom: 4rem; position: relative;">
      <div style="text-align: right; width: 120px; font-weight: bold; color: var(--teal);">Nov 2025 - NOW</div>
      <div style="flex: 1; border-left: 2px solid var(--teal); padding-left: 2rem; position: relative;">
        <div style="width: 12px; height: 12px; background: var(--teal); border-radius: 50%; position: absolute; left: -7px; top: 5px;"></div>
        <h3 style="margin: 0;">Optical Consultant</h3>
        <p style="color: #666; margin-bottom: 1rem;">***** Eye Care</p>
        <p style="font-size: 0.95rem;">Skills in luxury frames, consistent sales quotas, and deep patient care understanding.</p>
      </div>
    </div>

    <div style="display: flex; gap: 2rem; margin-bottom: 4rem;">
      <div style="text-align: right; width: 120px; font-weight: bold; color: #888;">2024 - 2025</div>
      <div style="flex: 1; border-left: 2px solid #ddd; padding-left: 2rem; position: relative;">
        <div style="width: 12px; height: 12px; background: #ddd; border-radius: 50%; position: absolute; left: -7px; top: 5px;"></div>
        <h3 style="margin: 0;">Optometric Technician</h3>
        <p style="color: #666;">National Vision</p>
        <p style="font-size: 0.95rem;">Expertise in tonometry, autorefractor, and retinal imaging. Managed remote optometrist systems.</p>
      </div>
    </div>

    <div style="display: flex; gap: 2rem; margin-bottom: 4rem;">
      <div style="text-align: right; width: 120px; font-weight: bold; color: #888;">2022 - 2023</div>
      <div style="flex: 1; border-left: 2px solid #ddd; padding-left: 2rem; position: relative;">
        <div style="width: 12px; height: 12px; background: #ddd; border-radius: 50%; position: absolute; left: -7px; top: 5px;"></div>
        <h3 style="margin: 0;">Retail Banker</h3>
        <p style="color: #666;">Woodforest Bank</p>
        <p style="font-size: 0.95rem;">Financial literacy, vault management, and Microsoft Proficiency.</p>
      </div>
    </div>
  </div>
</MainLayout>
