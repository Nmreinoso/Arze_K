---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="Resume | Karen Arze">
  <h2 style="color: #003366; border-bottom: 2px solid #a2c2e1; padding-bottom: 10px;">Work Experience</h2>

  <div style="margin: 30px 0; padding: 20px; border-radius: 12px; background: white; border: 1px solid #f0f0f0; box-shadow: 0 4px 10px rgba(0,0,0,0.03);">
    <span style="background: #003366; color: white; padding: 4px 12px; border-radius: 20px; font-size: 0.8rem;">Nov 2025 - Current</span>
    <h3 style="color: #0056b3; margin: 10px 0 5px 0;">Optical Consultant — ***** Eye Care</h3>
    <ul style="color: #444;">
      <li>Skills in fixing luxury glasses</li>
      <li>Consistently meet sale quotas</li>
      <li>Excellent at understanding and reaching customer eye care needs</li>
    </ul>
  </div>

  <div style="margin: 30px 0; padding: 20px; border-radius: 12px; background: white; border: 1px solid #f0f0f0;">
    <span style="background: #a2c2e1; color: #003366; padding: 4px 12px; border-radius: 20px; font-size: 0.8rem;">Jan 2024 – Sep 2025</span>
    <h3 style="color: #0056b3; margin: 10px 0 5px 0;">Optometric Technician & Sales Representative</h3>
    <p style="font-weight: bold; margin: 0;">National Vision/America’s Best</p>
    <ul style="color: #444; margin-top: 10px;">
      <li>Assisting Optometrist through digital systems for patient eye care testing.</li>
      <li>Proficiency in tonometer, autorefractor, retinal imaging, and visual field.</li>
      <li>Manage insurance eligibility and appointments.</li>
      <li>Trained new contact lens wearers.</li>
    </ul>
  </div>

  <div style="margin: 30px 0; padding: 20px;">
    <span style="background: #eef2f7; color: #003366; padding: 4px 12px; border-radius: 20px; font-size: 0.8rem;">Feb 2022 – Dec 2023</span>
    <h3 style="color: #0056b3; margin: 10px 0 5px 0;">Retail Banker — Woodforest Bank</h3>
    <p style="color: #444;">Handled transactions, branch goals, vault balancing, and Microsoft Proficiency.</p>
  </div>

  <div style="margin: 30px 0; padding: 20px;">
    <span style="background: #eef2f7; color: #003366; padding: 4px 12px; border-radius: 20px; font-size: 0.8rem;">2011 – 2013</span>
    <h3 style="color: #0056b3; margin: 10px 0 5px 0;">Manager — Salvation Army</h3>
    <p style="color: #444;">Simultaneously managed employee performance and product intake for 3 locations.</p>
  </div>
</MainLayout>
