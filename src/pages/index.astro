---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="Karen Arze | Welcome">
  <div class="glass-card">
    <div style="display: flex; flex-wrap: wrap; gap: 3rem; align-items: center;">
      <img src="/Arze_K/profile.jpg" alt="Karen Arze" style="width: 280px; height: 380px; object-fit: cover; border-radius: 100px 100px 20px 20px; background: #eee; box-shadow: 20px 20px 0px var(--teal);" />
      
      <div style="flex: 1; min-width: 300px;">
        <h1 style="font-size: 3.5rem; margin: 0;">Karen Arze</h1>
        <p style="font-size: 1.2rem; line-height: 1.6; margin-top: 1.5rem; color: #444;">
          { "Quick to adapt and eager to learn... I'm always enthusiastic to apply my experiences into an environment that appreciates organization and efficiency!" }
        </p>
        <div style="margin-top: 2rem; font-size: 0.9rem; border-top: 1px solid #ddd; padding-top: 1rem;">
          <p><strong>Virginia</strong> • 757-515-**** • karen**********@yahoo.com</p>
        </div>
      </div>
    </div>

    <div style="margin-top: 5rem;">
      <h2 style="text-align: center; margin-bottom: 3rem;">Things that make me smile</h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 2rem;">
        <div style="text-align: center;">
          <span style="font-size: 2.5rem;">🌊</span>
          <h4>Beach Sunrises</h4>
          <p style="font-size: 0.85rem;">The drive is always worth the view.</p>
        </div>
        <div style="text-align: center;">
          <span style="font-size: 2.5rem;">💃</span>
          <h4>Bachata & Salsa</h4>
          <p style="font-size: 0.85rem;">Dancing is where I find my true rhythm.</p>
        </div>
        <div style="text-align: center;">
          <span style="font-size: 2.5rem;">🍳</span>
          <h4>Kitchen Mastery</h4>
          <p style="font-size: 0.85rem;">Experimental cooking for the family heart.</p>
        </div>
        <div style="text-align: center;">
          <span style="font-size: 2.5rem;">❤️</span>
          <h4>My Grown Babies</h4>
          <p style="font-size: 0.85rem;">My pride and joy, always.</p>
        </div>
      </div>
    </div>
  </div>
</MainLayout>
