<style>
    /* 1. Global Variables */
    :root {
        --navy: #1a2a6c;
        --mist: #f0f4f8; /* Soft blue-grey for the 'empty' sides */
        --gold: #b89f6d;
        --white: #ffffff;
    }

    /* 2. The Background (The Empty Space) */
    html, body {
        margin: 0;
        padding: 0;
        background-color: var(--mist); /* This color fills the laptop sides */
        font-family: 'Montserrat', sans-serif;
    }

    /* 3. The Top Navigation */
    nav {
        background-color: var(--white);
        padding: 25px 0;
        display: flex;
        justify-content: center;
        border-bottom: 2px solid var(--gold);
    }

    nav a {
        margin: 0 20px;
        text-decoration: none;
        color: var(--navy);
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 2px;
        font-weight: 600;
    }

    /* 4. The Content Box (The Frame) */
    main {
        /* This fills more of the laptop screen */
        max-width: 1200px; 
        margin: 40px auto; /* Centers the box */
        background-color: var(--white);
        padding: 60px;
        
        /* Adds a subtle border and shadow so it looks like a professional document */
        border: 1px solid #d1d1d1;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        
        /* Ensures the box stays centered and visible */
        display: block;
        min-height: 80vh;
    }

    footer {
        text-align: center;
        padding: 40px;
        color: #777;
        font-size: 0.8rem;
    }

    /* Simple fix for mobile phones */
    @media (max-width: 1200px) {
        main {
            margin: 0;
            max-width: 100%;
            border: none;
        }
    }
</style>

<main>
        <slot />
    </main>
    <footer>...</footer>
  </body>
</html>
