---
const { title } = Astro.props;
---
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@600&family=Montserrat:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --navy: #1a2a6c;
            --mist: #eef2f6; 
            --gold: #b89f6d;
            --white: #ffffff;
        }
        body {
            margin: 0;
            font-family: 'Montserrat', sans-serif;
            background-color: var(--mist); 
            color: #333;
        }
        nav {
            display: flex;
            justify-content: center;
            padding: 2rem 0;
            background: var(--white);
            border-bottom: 2px solid var(--gold); 
            position: sticky;
            top: 0;
            z-index: 100;
        }
        nav a {
            margin: 0 20px;
            text-decoration: none;
            color: var(--navy);
            text-transform: uppercase;
            font-size: 0.8rem;
            letter-spacing: 2px;
            font-weight: 600;
        }
        nav a:hover { color: var(--gold); }
        
        /* THE MAIN EDIT: Enhanced Border and Centering */
        main {
            max-width: 1100px; /* Narrowed slightly to feel more 'centered' on wide screens */
            margin: 60px auto; /* Increased top/bottom margin for a more balanced vertical look */
            padding: 60px;     
            background: var(--white); 
            
            /* STANDOUT BORDER: A soft grey outer line with a gold 'inset' outline */
            border: 1px solid #d1d1d1; 
            outline: 2px solid var(--gold);
            outline-offset: -15px; /* This pulls the gold line inside the white box */
            
            /* Elevated shadow for a professional depth */
            box-shadow: 0 20px 40px rgba(0,0,0,0.08); 
            min-height: 80vh;
        }

        h1, h2, h3 { font-family: 'Cormorant Garamond', serif; color: var(--navy); }
        .page-header { text-align: center; margin-bottom: 60px; }
        footer { text-align: center; padding: 40px; font-size: 0.8rem; color: #999; }

        /* Ensuring it still looks good on phones */
        @media (max-width: 1200px) {
            main {
                margin: 0;
                padding: 30px 20px;
                border: none;
                outline: none; /* Removes the special border on mobile for better fit */
            }
        }
    </style>
</head>
