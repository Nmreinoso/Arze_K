---
const { title } = Astro.props;
---
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@600&family=Montserrat:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --navy: #1a2a6c;
            --mist: #f4f7f9; /* Your Light Blue */
            --gold: #b89f6d;
            --white: #ffffff;
        }
        body {
            margin: 0;
            font-family: 'Montserrat', sans-serif;
            background-color: var(--white); /* Outside is now white */
            color: #333;
        }
        nav {
            display: flex;
            justify-content: center;
            padding: 2rem 0;
            background: var(--white);
            border-bottom: 1px solid #e0e0e0;
            position: sticky;
            top: 0;
            z-index: 100;
        }
        nav a {
            margin: 0 20px;
            text-decoration: none;
            color: var(--navy);
            text-transform: uppercase;
            font-size: 0.8rem;
            letter-spacing: 2px;
            font-weight: 600;
        }
        nav a:hover { color: var(--gold); }

        main {
            max-width: 1000px; 
            margin: 50px auto; 
            padding: 60px;
            background: var(--mist); /* Inside is now light blue */
            
            /* Professional Borders */
            border-top: 6px solid var(--navy);
            border-left: 1px solid var(--gold);
            border-right: 1px solid var(--gold);
            border-bottom: 1px solid var(--gold);
            
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        }

        h1, h2, h3 { font-family: 'Cormorant Garamond', serif; color: var(--navy); }
        .page-header { text-align: center; margin-bottom: 60px; }
        footer { text-align: center; padding: 40px; font-size: 0.8rem; color: #999; }

        @media (max-width: 1000px) {
            main {
                margin: 0;
                border: none;
                padding: 40px 20px;
