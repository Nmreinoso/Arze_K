<style>
    :root {
        --navy: #1a2a6c;
        --mist: #f4f7f9; /* Soft background color */
        --gold: #b89f6d;
        --white: #ffffff;
    }

    /* 1. The Background: Fills the "Empty" laptop space */
    body {
        margin: 0;
        padding: 0;
        font-family: 'Montserrat', sans-serif;
        background-color: var(--mist);
        /* Subtle professional texture so the sides aren't "blank" */
        background-image: radial-gradient(rgba(184, 159, 109, 0.2) 1px, transparent 1px);
        background-size: 40px 40px;
        color: #333;
    }

    /* 2. The Navigation: Centered and Clean */
    nav {
        display: flex;
        justify-content: center;
        padding: 2rem 0;
        background: var(--white);
        border-bottom: 1px solid #e0e0e0;
        position: sticky;
        top: 0;
        z-index: 100;
    }

    nav a {
        margin: 0 20px;
        text-decoration: none;
        color: var(--navy);
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 2px;
        font-weight: 600;
    }

    /* 3. The Main Content: This "Hugs" your content and stops the empty feeling */
    main {
        max-width: 1200px; /* Wider for laptops */
        margin: 50px auto; /* Centers the content */
        padding: 60px;
        background: var(--white);
        
        /* THE FIX: Professional Border & Shadow to define the space */
        border: 1px solid #d1d1d1;
        border-top: 5px solid var(--navy); /* Professional accent top */
        box-shadow: 0 10px 50px rgba(0,0,0,0.08);
        border-radius: 4px;
        
        /* Ensures content doesn't touch the very edge of the white box */
