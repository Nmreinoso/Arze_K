---
const { title } = Astro.props;
---
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@600&family=Montserrat:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --navy: #1a2a6c;
            --mist: #eef2f6; 
            --gold: #b89f6d;
            --white: #ffffff;
        }
        body {
            margin: 0;
            font-family: 'Montserrat', sans-serif;
            background-color: var(--mist); 
            color: #333;
        }
        nav {
            display: flex;
            justify-content: center;
            padding: 2rem 0;
            background: var(--white);
            border-bottom: 2px solid var(--gold); 
            position: sticky;
            top: 0;
            z-index: 100;
        }
        nav a {
            margin: 0 20px;
            text-decoration: none;
            color: var(--navy);
            text-transform: uppercase;
            font-size: 0.8rem;
            letter-spacing: 2px;
            font-weight: 600;
        }
        nav a:hover { color: var(--gold); }
        
        main {
            /* 1. Centering: Reduced width slightly to make it feel more 'centered' on wide laptops */
            max-width: 1060px; 
            /* 2. Spacing: Increased top/bottom margin so the box sits in the middle of the screen */
            margin: 60px auto; 
            padding: 60px;
            background: var(--white);
            
            /* 3. The Border: A clean, high-contrast professional border that won't break the site */
            border: 8px solid var(--white);
            outline: 1px solid var(--gold); 
            box-shadow: 0 15px 50px rgba(0,0,0,0.1);
            
            min-height: 80vh;
        }

        h1, h2, h3 { font-family: 'Cormorant Garamond', serif; color: var(--navy); }
        .page-header { text-align: center; margin-bottom: 60px; }
        footer { text-align: center; padding: 40px; font-size: 0.8rem; color: #999; }

