---
const { title } = Astro.props;
---
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@600&family=Montserrat:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --navy: #1a2a6c;
            --mist: #eef2f6; /* Slightly deeper mist to define the sides better */
            --gold: #b89f6d;
            --white: #ffffff;
        }
        body {
            margin: 0;
            font-family: 'Montserrat', sans-serif;
            background-color: var(--mist); /* Fills the laptop's side empty space */
            color: #333;
        }
        nav {
            display: flex;
            justify-content: center;
            padding: 2rem 0;
            background: var(--white);
            border-bottom: 2px solid var(--gold); /* Added gold for a stronger top border */
            position: sticky;
            top: 0;
            z-index: 100;
        }
        nav a {
            margin: 0 20px;
            text-decoration: none;
            color: var(--navy);
            text-transform: uppercase;
            font-size: 0.8rem;
            letter-spacing: 2px;
            font-weight: 600;
        }
        nav a:hover { color: var(--gold); }
        
        /* THE MAIN EDIT: Creating the "Portfolio" frame */
        main {
            max-width: 1200px; /* Wider to occupy more laptop screen */
            margin: 40px auto; /* Adds space at the top/bottom so it doesn't touch the edges */
            padding: 60px;     /* More internal room for your content */
            background: var(--white); /* White box for your content */
            border: 1px solid #d1d1d1; /* Soft grey border to define the shape */
            box-shadow: 0 10px 30px rgba(0,0,0,0.05); /* Soft shadow to give it depth */
            min-height: 80vh;
        }

        h1, h2, h3 { font-family: 'Cormorant Garamond', serif; color: var(--navy); }
        .page-header { text-align: center; margin-bottom: 60px; }
        footer { text-align: center; padding: 40px; font-size: 0.8rem; color: #999; }

        /* Ensuring it still looks good on phones */
        @media (max-width: 1200px) {
            main {
                margin: 0;
                padding: 30px 20px;
                border: none;
            }
        }
    </style>
</head>
<body>
    <nav>
        <a href="/Arze_K/">Home</a>
        <a href="/Arze_K/resume/">Resume</a>
        <a href="/Arze_K/blog/">Blog</a>
    </nav>
    <main>
        <slot />
    </main>
    <footer>© 2026 Karen Arze | Professional & Personal Portfolio</footer>
</body>
</html>
