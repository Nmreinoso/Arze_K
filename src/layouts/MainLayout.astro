---
const { title } = Astro.props;
---
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@600&family=Montserrat:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --navy: #1a2a6c;
            --mist: #f4f7f9; /* Light Blue */
            --gold: #b89f6d;
            --white: #ffffff;
        }

        /* OUTSIDE: Pure White */
        body {
            margin: 0;
            padding: 0;
            background-color: #ffffff; 
            font-family: 'Montserrat', sans-serif;
            color: #333;
        }

        nav {
            display: flex;
            justify-content: center;
            padding: 30px 0;
            background-color: #ffffff;
            border-bottom: 1px solid #dddddd;
        }

        nav a {
            margin: 0 20px;
            text-decoration: none;
            color: var(--navy);
            text-transform: uppercase;
            font-size: 0.8rem;
            letter-spacing: 2px;
            font-weight: 600;
        }

        /* INSIDE: Light Blue with standard borders */
        main {
            max-width: 1000px;
            margin-top: 50px;
            margin-bottom: 50px;
            margin-left: auto;
            margin-right: auto;
            padding: 50px;
            background-color: #f4f7f9; /* Light Blue */
            
            /* Stable Borders */
            border-top: 6px solid #1a2a6c; /* Navy */
            border-right: 2px solid #b89f6d; /* Gold */
            border-bottom: 2px solid #b89f6d; /* Gold */
            border-left: 2px solid #b89f6d; /* Gold */
        }

        h1, h2, h3 { 
            font-family: 'Cormorant Garamond', serif; 
            color: #1a2a6c; 
        }

        footer {
            text-align: center;
            padding: 40px;
            font-size: 0.8rem;
            color: #999;
        }

        /* Mobile Fix */
        @media (max-width: 1000px) {
            main {
                margin: 0;
                width: 100%;
                border: none;
                padding: 20px;
            }
        }
    </style>
</head>
<body>
    <nav>
        <a href="/Arze_K/">Home</a>
        <a href="/Arze_K/resume/">Resume</a>
        <a href="/Arze_K/blog/">Blog</a>
    </nav>
    <main>
        <slot />
    </main>
    <footer>© 2026 Karen Arze | Professional & Personal Portfolio</footer>
</body>
</html>
