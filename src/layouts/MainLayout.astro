---
const { title } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      :root { --navy: #003366; --soft-blue: #f0f7ff; --accent: #a2c2e1; }
      body { background: var(--soft-blue); font-family: sans-serif; margin: 0; color: #333; }
      nav { background: white; padding: 1rem; border-bottom: 4px solid var(--accent); display: flex; justify-content: center; gap: 20px; }
      nav a { text-decoration: none; color: #0056b3; font-weight: bold; }
      main { max-width: 800px; margin: 40px auto; padding: 40px; background: white; border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); }
    </style>
  </head>
  <body>
    <nav>
      <a href="/Arze_K/">Home</a>
      <a href="/Arze_K/resume">Resume</a>
      <a href="/Arze_K/blog">Blog</a>
    </nav>
    <main>
      <slot />
    </main>
  </body>
</html>
