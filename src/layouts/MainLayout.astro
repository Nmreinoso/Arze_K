---
const { title } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Plus+Jakarta+Sans:wght@300;400;600&display=swap');

      :root {
        --navy: #002b5b;
        --teal: #64ccc5;
        --mist: #f2f7ff;
        --sand: #faf9f6;
      }

      body {
        background: linear-gradient(135deg, var(--mist) 0%, #ffffff 100%);
        font-family: 'Plus Jakarta Sans', sans-serif;
        margin: 0;
        color: var(--navy);
      }

      nav {
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(10px);
        padding: 1.5rem;
        position: sticky;
        top: 0;
        display: flex;
        justify-content: center;
        gap: 2rem;
        z-index: 100;
        border-bottom: 1px solid rgba(0,0,0,0.05);
      }

      nav a {
        text-decoration: none;
        color: var(--navy);
        font-weight: 600;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        font-size: 0.85rem;
      }

      nav a:hover { color: var(--teal); }

      main {
        max-width: 900px;
        margin: 2rem auto;
        padding: 2rem;
      }

      h1, h2, h3 { font-family: 'Playfair Display', serif; }

      .glass-card {
        background: rgba(255, 255, 255, 0.7);
        border: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 24px;
        padding: 2.5rem;
        box-shadow: 0 20px 40px rgba(0, 43, 91, 0.04);
      }

      footer { text-align: center; padding: 3rem; font-size: 0.8rem; opacity: 0.6; }
    </style>
  </head>
  <body>
    <nav>
      <a href="/Arze_K/">Home</a>
      <a href="/Arze_K/resume/">Resume</a>
      <a href="/Arze_K/blog/">Blog</a>
    </nav>
    <main>
      <slot />
    </main>
    <footer>© 2026 KAREN ARZE | Optometrist & Mother</footer>
  </body>
</html>
