---
const { title } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      /* Theme: Professional Optometrist & Loving Mother */
      :root {
        --primary-blue: #003366; /* Trust and Professionalism */
        --warm-white: #ffffff;
        --sky-blue: #f0f7ff;    /* Approachability */
        --accent-blue: #a2c2e1;  /* Softness and Sympathy */
      }

      body {
        background-color: var(--sky-blue);
        color: #333;
        font-family: 'Helvetica Neue', Arial, sans-serif;
        margin: 0;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }

      nav {
        background: var(--warm-white);
        padding: 1.5rem;
        border-bottom: 4px solid var(--accent-blue);
        display: flex;
        justify-content: center;
        gap: 40px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.05);
      }

      nav a {
        text-decoration: none;
        color: var(--primary-blue);
        font-weight: bold;
        font-size: 1.1rem;
        transition: color 0.3s ease;
      }

      nav a:hover {
        color: var(--accent-blue);
      }

      main {
        flex: 1;
        max-width: 800px;
        margin: 40px auto;
        padding: 40px;
        background: var(--warm-white);
        border-radius: 25px; /* Softer, maternal touch */
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
      }

      footer {
        text-align: center;
        padding: 2rem;
        font-size: 0.9rem;
        color: #666;
        border-top: 1px solid var(--accent-blue);
        margin-top: 40px;
      }
    </style>
  </head>
  <body>
    <nav>
      <a href="/Arze_K/">Home</a>
      <a href="/Arze_K/resume/">Resume</a>
      <a href="/Arze_K/blog/">Blog</a>
    </nav>

    <main>
      <slot /> </main>

    <footer>
      <p>Professional Optometrist | Loving Mother | Karen Arze © 2026</p>
    </footer>
  </body>
</html>
